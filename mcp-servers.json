{
  "mcpServers": {
    "fanhub-api": {
      "command": "node",
      "args": ["${workspaceFolder}/mcp-servers/fanhub-api-server.js"],
      "env": {
        "FANHUB_API_URL": "http://localhost:5265"
      }
    },
    "fanhub-db-dotnet": {
      "command": "npx",
      "args": ["-y", "mcp-sqlite", "${workspaceFolder}/dotnet/Backend/fanhub.db"]
    },
    "fanhub-db-node": {
      "command": "npx",
      "args": ["-y", "mcp-sqlite", "${workspaceFolder}/node/Backend/fanhub.db"]
    },
    "fanhub-db-java": {
      "command": "npx",
      "args": ["-y", "mcp-sqlite", "${workspaceFolder}/java/Backend/fanhub.db"]
    },
    "fanhub-db-go": {
      "command": "npx",
      "args": ["-y", "mcp-sqlite", "${workspaceFolder}/go/Backend/fanhub.db"]
    }
  }
}
